  "keyFeatures": [
    "Federated SQL query across 30+ data sources",
    "Multi-engine data acceleration (Arrow, DuckDB, SQLite, PostgreSQL, Cayenne)",
    "Petabyte-scale vector search with Amazon S3 Vectors",
    "Full-text and keyword search with Tantivy BM25",
    "OpenAI-compatible API for local and hosted LLM inference",
    "Distributed multi-node query execution with Apache Ballista",
    "Apache Iceberg table writes and catalog integration",
    "Model Context Protocol (MCP) for AI agent integration"
  ],
  "publicApiSurface": [
    "HTTP /v1/sql - Execute SQL queries",
    "HTTP /v1/chat/completions - OpenAI-compatible chat API",
    "HTTP /v1/embeddings - Generate embeddings",
    "HTTP /v1/search - Vector and full-text search",
    "HTTP /v1/datasets - Manage datasets",
    "HTTP /v1/models - Manage models",
    "Arrow Flight - High-performance data streaming",
    "Arrow Flight SQL - SQL over Arrow Flight",
    "ODBC/JDBC - Standard database connectivity",
    "spice init - Initialize new project",
    "spice run - Start runtime daemon",
    "spice sql - Interactive SQL REPL",
    "spice add - Add dependencies to Spicepod",
    "spice dataset configure - Configure datasets",
    "vector_search() - SQL UDTF for vector similarity search",
    "text_search() - SQL UDTF for full-text search"
  ]
